<!DOCTYPE html>
<html lang="{{ t.html_lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }}</title>
{{ seo_head | safe }}
  <link rel="stylesheet" href="/css/site.css">
  <script src="/js/i18n.js"></script>
</head>
<body>
  <header class="site-header">
    <div class="wrap header-inner">
      <a class="brand brand-gradient" href="{{ urls.home }}">ARNGCOR</a>
      <div class="header-actions">
        <nav class="site-nav" aria-label="{{ t.nav.aria }}">
          <a href="{{ urls.home }}" class="nav-link{% if active == 'home' %} is-active{% endif %}">{{ t.nav.home }}</a>
          <a href="{{ urls.about }}" class="nav-link{% if active == 'about' %} is-active{% endif %}">{{ t.nav.about }}</a>
          <a href="{{ urls.privacy }}" class="nav-link{% if active == 'privacy' %} is-active{% endif %}">{{ t.nav.privacy }}</a>
          <a href="{{ urls.terms }}" class="nav-link{% if active == 'terms' %} is-active{% endif %}">{{ t.nav.terms }}</a>
        </nav>
        <div class="lang-dropdown">
          <button
            type="button"
            class="lang-dropdown__trigger"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="lang-menu"
            id="lang-trigger"
          >
            <span class="lang-dropdown__label">{% if t.locale == 'pl' %}{{ t.lang.pl }}{% else %}{{ t.lang.en }}{% endif %}</span>
            <svg class="lang-dropdown__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <ul class="lang-dropdown__menu" id="lang-menu" role="listbox" aria-label="{{ t.lang.aria }}" hidden>
            {% if t.locale == 'pl' %}
            <li role="presentation">
              <button type="button" role="option" data-lang="en" class="lang-dropdown__option">{{ t.lang.en }}</button>
            </li>
            {% else %}
            <li role="presentation">
              <button type="button" role="option" data-lang="pl" class="lang-dropdown__option">{{ t.lang.pl }}</button>
            </li>
            {% endif %}
          </ul>
        </div>
      </div>
    </div>
  </header>

  {% block content %}{% endblock %}

  <footer class="site-footer">
    <div class="wrap footer-grid">
      <div>
        <div class="footer-brand brand-gradient">ARNGCOR</div>
        <p class="footer-tagline">{{ t.footer.tagline }}</p>
      </div>
      <div class="footer-links">
        <a href="{{ urls.about }}">{{ t.nav.about }}</a>
        <a href="{{ urls.privacy }}">{{ t.nav.privacy }}</a>
        <a href="{{ urls.terms }}">{{ t.nav.terms }}</a>
        <a href="mailto:kontakt@arngcor.pl">{{ t.footer.contact }}</a>
      </div>
    </div>
    <div class="wrap footer-bottom">
      <span>{{ t.footer.copyright }}</span>
      <span><a href="mailto:kontakt@arngcor.pl">kontakt@arngcor.pl</a></span>
    </div>
  </footer>

  <script src="/js/site.js" defer></script>
</body>
</html>
